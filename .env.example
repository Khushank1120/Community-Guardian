# Optional OpenAI settings for AI digest + optional confidence adjustment.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Optional debug output for AI errors.
AI_DEBUG=false

# Rule threshold for verification queue.
CONFIDENCE_REVIEW_THRESHOLD=0.60

# Contradiction gate:
# If a report claims high trust (verified or official/news/sensor)
# but AI confidence is below threshold, force needsReview=true.
AI_CONTRADICTION_GATE_ENABLED=true
AI_CONTRADICTION_LOW_THRESHOLD=0.30

# Encryption keys for users DB at rest.
# Option A (single key):
USERS_DB_KEY=
# Option B (versioned key ring, semicolon-separated version:key entries):
# USERS_DB_KEYS=v1:users-key-v1;v2:users-key-v2
# USERS_DB_ACTIVE_VERSION=v2

# Field-level encryption keys for incident sensitive fields (location).
INCIDENT_DATA_KEY=
# INCIDENT_DATA_KEYS=v1:incident-key-v1;v2:incident-key-v2
# INCIDENT_DATA_ACTIVE_VERSION=v2

# Integrity protection key for CSV tamper detection signatures.
DATA_INTEGRITY_KEY=
# DATA_INTEGRITY_KEYS=v1:integrity-key-v1;v2:integrity-key-v2
# DATA_INTEGRITY_ACTIVE_VERSION=v2

# Auth security controls.
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCKOUT_MINUTES=15

# Optional audit log path.
AUDIT_LOG_PATH=data/audit.log
